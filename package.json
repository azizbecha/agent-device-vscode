{
  "name": "agent-device-vscode",
  "displayName": "Agent Device",
  "description": "Author, run, and inspect agent-device .ad scripts inside VS Code.",
  "version": "0.0.1",
  "publisher": "agent-device",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/azizbecha/agent-device-vscode"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages",
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:agent-device",
    "onView:agentDevice.runOutput"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "agent-device",
        "aliases": [
          "Agent Device",
          "agent-device"
        ],
        "extensions": [
          ".ad"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "agent-device",
        "scopeName": "source.agent-device",
        "path": "./syntaxes/agent-device.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "agentDevice.runScript",
        "title": "Run Script",
        "category": "Agent Device"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "agent-device",
          "title": "Agent Device",
          "icon": "media/agent-device.svg"
        }
      ]
    },
    "views": {
      "agent-device": [
        {
          "type": "webview",
          "id": "agentDevice.runOutput",
          "name": "Run Output"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "agent-device": "^0.14.7"
  }
}
