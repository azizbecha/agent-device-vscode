{
  "name": "agent-device-vscode",
  "displayName": "Agent Device",
  "description": "Author, run, and inspect agent-device .ad scripts inside VS Code.",
  "version": "0.0.1",
  "publisher": "agent-device",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/azizbecha/agent-device-vscode"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages",
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:agent-device",
    "onView:agentDevice.runOutput"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "agent-device",
        "aliases": [
          "Agent Device",
          "agent-device"
        ],
        "extensions": [
          ".ad"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "agent-device",
        "scopeName": "source.agent-device",
        "path": "./syntaxes/agent-device.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "agentDevice.runScript",
        "title": "Run Script",
        "category": "Agent Device"
      },
      {
        "command": "agentDevice.cancelRun",
        "title": "Cancel Run",
        "category": "Agent Device",
        "icon": "$(debug-stop)"
      },
      {
        "command": "agentDevice.newScript",
        "title": "New .ad Script",
        "category": "Agent Device",
        "icon": "$(new-file)"
      },
      {
        "command": "agentDevice.refreshDevices",
        "title": "Refresh Devices",
        "category": "Agent Device",
        "icon": "$(refresh)"
      },
      {
        "command": "agentDevice.bootDevice",
        "title": "Boot",
        "category": "Agent Device",
        "icon": "$(play)"
      },
      {
        "command": "agentDevice.shutdownDevice",
        "title": "Shut Down",
        "category": "Agent Device",
        "icon": "$(debug-stop)"
      },
      {
        "command": "agentDevice.openLastReport",
        "title": "Open Last Report",
        "category": "Agent Device",
        "icon": "$(file-symlink-file)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentDevice.refreshDevices",
          "when": "view == agentDevice.devices",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agentDevice.bootDevice",
          "when": "view == agentDevice.devices && viewItem == agentDevice.device.shutdown",
          "group": "inline"
        },
        {
          "command": "agentDevice.bootDevice",
          "when": "view == agentDevice.devices && viewItem == agentDevice.device.shutdown",
          "group": "1_actions"
        },
        {
          "command": "agentDevice.shutdownDevice",
          "when": "view == agentDevice.devices && viewItem == agentDevice.device.booted",
          "group": "inline"
        },
        {
          "command": "agentDevice.shutdownDevice",
          "when": "view == agentDevice.devices && viewItem == agentDevice.device.booted",
          "group": "1_actions"
        }
      ]
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "agent-device",
          "title": "Agent Device",
          "icon": "media/agent-device.svg"
        }
      ]
    },
    "views": {
      "agent-device": [
        {
          "type": "webview",
          "id": "agentDevice.runOutput",
          "name": "Run Output"
        },
        {
          "id": "agentDevice.devices",
          "name": "Devices"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.95.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "agent-device": "^0.14.7"
  }
}
