{
  "name": "agent-device-vscode",
  "displayName": "Agent Device",
  "version": "0.0.1",
  "private": true,
  "description": "Author, run, and inspect agent-device .ad scripts inside VS Code.",
  "categories": [
    "Other",
    "Programming Languages",
    "Testing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/azizbecha/agent-device-vscode"
  },
  "publisher": "agent-device",
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "agent-device": "^0.14.7"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.95.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.2.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "contributes": {
    "languages": [
      {
        "id": "agent-device",
        "aliases": [
          "Agent Device",
          "agent-device"
        ],
        "extensions": [
          ".ad"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "agent-device",
        "scopeName": "source.agent-device",
        "path": "./syntaxes/agent-device.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "agentDevice.runScript",
        "title": "Run Script",
        "category": "Agent Device"
      },
      {
        "command": "agentDevice.cancelRun",
        "title": "Cancel Run",
        "category": "Agent Device",
        "icon": "$(debug-stop)"
      },
      {
        "command": "agentDevice.newScript",
        "title": "New .ad Script",
        "category": "Agent Device",
        "icon": "$(new-file)"
      },
      {
        "command": "agentDevice.refreshDevices",
        "title": "Refresh Devices",
        "category": "Agent Device",
        "icon": "$(refresh)"
      },
      {
        "command": "agentDevice.bootDevice",
        "title": "Boot",
        "category": "Agent Device",
        "icon": "$(play)"
      },
      {
        "command": "agentDevice.shutdownDevice",
        "title": "Shut Down",
        "category": "Agent Device",
        "icon": "$(debug-stop)"
      },
      {
        "command": "agentDevice.openLastReport",
        "title": "Open Last Report",
        "category": "Agent Device",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "agentDevice.openSettings",
        "title": "Open Settings",
        "category": "Agent Device",
        "icon": "$(gear)"
      },
      {
        "command": "agentDevice.refreshSnapshot",
        "title": "Refresh Snapshot",
        "category": "Agent Device",
        "icon": "$(refresh)"
      },
      {
        "command": "agentDevice.clearSnapshot",
        "title": "Clear Snapshot",
        "category": "Agent Device",
        "icon": "$(clear-all)"
      }
    ],
    "keybindings": [
      {
        "command": "agentDevice.runScript",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorLangId == agent-device"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentDevice.refreshDevices",
          "when": "view == agentDevice.devices",
          "group": "navigation@1"
        },
        {
          "command": "agentDevice.refreshSnapshot",
          "when": "view == agentDevice.snapshotInspector",
          "group": "navigation@1"
        },
        {
          "command": "agentDevice.clearSnapshot",
          "when": "view == agentDevice.snapshotInspector",
          "group": "navigation@2"
        },
        {
          "command": "agentDevice.openSettings",
          "when": "view == agentDevice.devices || view == agentDevice.runOutput || view == agentDevice.snapshotInspector",
          "group": "navigation@9"
        }
      ],
      "view/item/context": [
        {
          "command": "agentDevice.bootDevice",
          "when": "view == agentDevice.devices && viewItem == agentDevice.device.shutdown",
          "group": "inline"
        },
        {
          "command": "agentDevice.bootDevice",
          "when": "view == agentDevice.devices && viewItem == agentDevice.device.shutdown",
          "group": "1_actions"
        },
        {
          "command": "agentDevice.shutdownDevice",
          "when": "view == agentDevice.devices && viewItem == agentDevice.device.booted",
          "group": "inline"
        },
        {
          "command": "agentDevice.shutdownDevice",
          "when": "view == agentDevice.devices && viewItem == agentDevice.device.booted",
          "group": "1_actions"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-device-sidebar",
          "title": "Agent Device",
          "icon": "media/agent-device.svg"
        }
      ],
      "panel": [
        {
          "id": "agent-device",
          "title": "Agent Device",
          "icon": "media/agent-device.svg"
        }
      ]
    },
    "views": {
      "agent-device-sidebar": [
        {
          "type": "webview",
          "id": "agentDevice.settings",
          "name": "Settings"
        },
        {
          "id": "agentDevice.devices",
          "name": "Devices"
        },
        {
          "type": "webview",
          "id": "agentDevice.snapshotInspector",
          "name": "Snapshot"
        }
      ],
      "agent-device": [
        {
          "type": "webview",
          "id": "agentDevice.runOutput",
          "name": "Run Output"
        }
      ]
    },
    "configuration": {
      "title": "Agent Device",
      "properties": {
        "agentDevice.cliPath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Absolute path to the agent-device CLI binary. Leave empty to use the version bundled with the extension."
        },
        "agentDevice.session": {
          "type": "string",
          "default": "vscode",
          "description": "Session name passed to the agent-device daemon for replay runs."
        },
        "agentDevice.androidSdkPath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Override for the Android SDK location used to find adb and emulator. Falls back to ANDROID_HOME / ANDROID_SDK_ROOT, then PATH."
        },
        "agentDevice.report.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Generate an HTML report under .agent-device-reports/ after every run."
        },
        "agentDevice.notifications.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a popup notification when a run finishes (status bar pill always shows)."
        }
      }
    }
  },
  "activationEvents": [
    "onCommand:agentDevice.newScript",
    "onCommand:agentDevice.openLastReport",
    "onCommand:agentDevice.openSettings",
    "onCommand:agentDevice.runScript",
    "onLanguage:agent-device",
    "onView:agentDevice.devices",
    "onView:agentDevice.runOutput",
    "onView:agentDevice.settings",
    "onView:agentDevice.snapshotInspector"
  ],
  "engines": {
    "vscode": "^1.95.0"
  }
}
